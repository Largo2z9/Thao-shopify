{%- comment -%} THAO — Sticky Header (snippet, no section wrapper) {%- endcomment -%}

<style>
  .thao-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 9999;
    height: var(--header-height);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 var(--padding-x-mobile);
    background-color: var(--thao-bg);
    transition: box-shadow var(--duration-slow) var(--ease-default);
  }

  .thao-header.is-scrolled {
    box-shadow: 0 1px 0 var(--thao-border);
  }

  @media (min-width: 750px) {
    .thao-header {
      padding: 0 var(--padding-x-desktop);
    }
  }

  .thao-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    max-width: var(--container-max);
  }

  .thao-header__logo {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    align-items: center;
  }

  .thao-header__logo img {
    height: 28px;
    width: auto;
  }

  .thao-header__spacer {
    width: 44px;
  }

  .thao-header__cart {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--thao-burgundy);
    text-decoration: none;
    transition: opacity var(--duration-base) var(--ease-default);
  }

  .thao-header__cart:hover {
    opacity: 0.7;
  }

  .thao-header__cart-count {
    position: absolute;
    top: 4px;
    right: 2px;
    min-width: 18px;
    height: 18px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 10px;
    background-color: var(--thao-burgundy);
    color: #FFFFFF;
    border-radius: 50%;
    padding: 0 4px;
  }

  .thao-header__cart-count:empty {
    display: none;
  }

  .thao-header-spacer {
    height: var(--header-height);
  }
</style>

<header class="thao-header" id="thao-header">
  <div class="thao-header__inner">
    <div class="thao-header__spacer"></div>

    <a href="/" class="thao-header__logo" aria-label="{{ shop.name }}">
      <img src="{{ 'logo-thao-burgundy.svg' | asset_url }}" alt="{{ shop.name }}" width="100" height="28" loading="eager">
    </a>

    <a href="{{ routes.cart_url }}" class="thao-header__cart" aria-label="Panier ({{ cart.item_count }})">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/>
        <line x1="3" y1="6" x2="21" y2="6"/>
        <path d="M16 10a4 4 0 01-8 0"/>
      </svg>
      <span class="thao-header__cart-count" id="thao-cart-count">
        {%- if cart.item_count > 0 -%}{{ cart.item_count }}{%- endif -%}
      </span>
    </a>
  </div>
</header>

<div class="thao-header-spacer"></div>

<script>
  (function () {
    var header = document.getElementById('thao-header');
    if (!header) return;
    var ticking = false;
    window.addEventListener('scroll', function () {
      if (!ticking) {
        window.requestAnimationFrame(function () {
          header.classList.toggle('is-scrolled', window.scrollY > 20);
          ticking = false;
        });
        ticking = true;
      }
    });
  })();
</script>
