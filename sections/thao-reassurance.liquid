{%- comment -%} THAO — Reassurance Icons {%- endcomment -%}

<style>
  .thao-reassurance__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-6) var(--space-5);
  }

  @media (min-width: 750px) {
    .thao-reassurance__grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .thao-reassurance__item {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
  }

  .thao-reassurance__icon {
    width: 32px;
    height: 32px;
    color: var(--thao-burgundy);
  }

  .thao-reassurance__title {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: var(--ui-size);
    color: var(--thao-text);
    line-height: var(--lh-ui);
  }

  .thao-reassurance__desc {
    font-family: var(--font-body);
    font-size: var(--caption-desktop);
    color: var(--thao-text-secondary);
    line-height: var(--lh-ui);
    margin-top: 2px;
  }
</style>

<section class="thao-section" style="background-color: var(--thao-bg-white);">
  <div class="thao-container">
    <div class="thao-reassurance__grid thao-reveal">

      <div class="thao-reassurance__item">
        <svg class="thao-reassurance__icon" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M4 16l6 6L28 6"/>
        </svg>
        <div>
          <div class="thao-reassurance__title">Livraison offerte</div>
          <div class="thao-reassurance__desc">Dès 40€ d'achat</div>
        </div>
      </div>

      <div class="thao-reassurance__item">
        <svg class="thao-reassurance__icon" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M4 16c0-6.6 5.4-12 12-12s12 5.4 12 12-5.4 12-12 12"/>
          <polyline points="16 8 16 16 20 20"/>
        </svg>
        <div>
          <div class="thao-reassurance__title">Retours gratuits</div>
          <div class="thao-reassurance__desc">Sous 30 jours</div>
        </div>
      </div>

      <div class="thao-reassurance__item">
        <svg class="thao-reassurance__icon" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="16" cy="16" r="12"/>
          <path d="M16 10v6"/>
          <circle cx="16" cy="21" r="1" fill="currentColor"/>
        </svg>
        <div>
          <div class="thao-reassurance__title">Coton premium</div>
          <div class="thao-reassurance__desc">Doux et respirant</div>
        </div>
      </div>

      <div class="thao-reassurance__item">
        <svg class="thao-reassurance__icon" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M16 4l3.09 6.26L26 11.27l-5 4.87L22.18 23 16 19.77 9.82 23 11 16.14l-5-4.87 6.91-1.01z"/>
        </svg>
        <div>
          <div class="thao-reassurance__title">Design exclusif</div>
          <div class="thao-reassurance__desc">Créé en France</div>
        </div>
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "THAO Reassurance",
  "class": "section-thao-reassurance",
  "settings": [],
  "presets": [{ "name": "THAO Reassurance" }]
}
{% endschema %}
