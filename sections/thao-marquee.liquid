{%- comment -%} THAO — Social Proof Marquee {%- endcomment -%}

<style>
  .thao-marquee {
    background-color: var(--thao-burgundy);
    height: 48px;
    overflow: hidden;
    display: flex;
    align-items: center;
  }

  .thao-marquee__track {
    display: flex;
    white-space: nowrap;
    animation: thao-marquee-scroll 30s linear infinite;
  }

  .thao-marquee:hover .thao-marquee__track {
    animation-play-state: paused;
  }

  .thao-marquee__item {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 0 var(--space-7);
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 13px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #FFFFFF;
  }

  .thao-marquee__dot {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.4);
    flex-shrink: 0;
  }

  @keyframes thao-marquee-scroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
</style>

<section class="thao-marquee" aria-label="Avantages">
  <div class="thao-marquee__track">
    {%- for i in (1..2) -%}
      <span class="thao-marquee__item">★★★★★ 4.9/5</span>
      <span class="thao-marquee__dot"></span>
      <span class="thao-marquee__item">{{ section.settings.item_1 | default: 'Livraison offerte dès 40€' }}</span>
      <span class="thao-marquee__dot"></span>
      <span class="thao-marquee__item">{{ section.settings.item_2 | default: 'Retours 30 jours' }}</span>
      <span class="thao-marquee__dot"></span>
      <span class="thao-marquee__item">{{ section.settings.item_3 | default: 'Coton premium' }}</span>
      <span class="thao-marquee__dot"></span>
      <span class="thao-marquee__item">{{ section.settings.item_4 | default: 'Made for pilates' }}</span>
      <span class="thao-marquee__dot"></span>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "THAO Marquee",
  "class": "section-thao-marquee",
  "settings": [
    { "type": "text", "id": "item_1", "label": "Item 1", "default": "Livraison offerte dès 40€" },
    { "type": "text", "id": "item_2", "label": "Item 2", "default": "Retours 30 jours" },
    { "type": "text", "id": "item_3", "label": "Item 3", "default": "Coton premium" },
    { "type": "text", "id": "item_4", "label": "Item 4", "default": "Made for pilates" }
  ],
  "presets": [{ "name": "THAO Marquee" }]
}
{% endschema %}
