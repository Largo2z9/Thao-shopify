{%- comment -%} THAO — Lifestyle / UGC Grid {%- endcomment -%}

<style>
  .thao-lifestyle__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-2);
  }

  @media (min-width: 750px) {
    .thao-lifestyle__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .thao-lifestyle__item {
    aspect-ratio: 1;
    border-radius: var(--radius-card);
    overflow: hidden;
    position: relative;
    background-color: var(--thao-bg);
  }

  .thao-lifestyle__item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 400ms var(--ease-default);
  }

  .thao-lifestyle__item:hover img {
    transform: scale(1.02);
  }

  .thao-lifestyle__placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--thao-text-secondary);
    font-family: var(--font-body);
    font-size: var(--caption-desktop);
  }

  .thao-lifestyle__caption {
    text-align: center;
    padding-top: var(--space-5);
    font-family: var(--font-body);
    font-size: var(--caption-desktop);
    color: var(--thao-text-secondary);
    letter-spacing: var(--ls-ui);
  }
</style>

<section class="thao-section" id="lifestyle">
  <div class="thao-container">
    <div class="thao-lifestyle__grid thao-reveal">
      {%- for i in (1..6) -%}
        {%- assign img_key = 'image_' | append: i -%}
        <div class="thao-lifestyle__item">
          {%- if section.settings[img_key] != blank -%}
            {{ section.settings[img_key] | image_url: width: 600 | image_tag:
              loading: 'lazy',
              sizes: '(min-width: 750px) 33vw, 50vw',
              widths: '300,400,600',
              alt: 'THAO lifestyle'
            }}
          {%- else -%}
            <div class="thao-lifestyle__placeholder">UGC {{ i }}</div>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
    <p class="thao-lifestyle__caption thao-reveal">@thao</p>
  </div>
</section>

{% schema %}
{
  "name": "THAO Lifestyle",
  "class": "section-thao-lifestyle",
  "settings": [
    { "type": "image_picker", "id": "image_1", "label": "Image 1" },
    { "type": "image_picker", "id": "image_2", "label": "Image 2" },
    { "type": "image_picker", "id": "image_3", "label": "Image 3" },
    { "type": "image_picker", "id": "image_4", "label": "Image 4" },
    { "type": "image_picker", "id": "image_5", "label": "Image 5" },
    { "type": "image_picker", "id": "image_6", "label": "Image 6" }
  ],
  "presets": [{ "name": "THAO Lifestyle" }]
}
{% endschema %}
